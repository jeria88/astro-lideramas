---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'LíderA+ — plataforma de IA para equipos directivos escolares. Automatizamos lo operativo para que usted lidere lo pedagógico.',
  ogImage = '/assets/logo-lideramas.jpeg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="LíderA+" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="icon" type="image/jpeg" href="/assets/logo-lideramas.jpeg" />

  <script type="application/ld+json" is:inline>{JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://lideramas-web.pages.dev/#org",
        "name": "LíderA+",
        "url": "https://lideramas-web.pages.dev"
      },
      {
        "@type": "SoftwareApplication",
        "name": "LíderA+",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "description": "Plataforma de IA para liderazgo pedagógico y gestión de redes educativas: asistentes por rol, actas automáticas de reuniones, monitoreo predictivo y normativa vigente."
      }
    ]
  })}</script>

  <slot name="head" />
  <script defer src="https://analytics.146.181.39.4.sslip.io/script.js" data-website-id="a66f3227-a6af-4cf4-9d1b-5016a3926054"></script>
</head>
<body>
  <Nav />
  <slot />
  <Footer />
</body>
</html>
